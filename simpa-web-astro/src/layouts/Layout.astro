---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
  lang?: 'tr' | 'en';
}
const { title, lang = 'tr' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="wrap">
  <div class="frame">
  <div class="topbar"><div class="topbar-in">
    <a href="tel:+902164996962">📞 +90 216 499 69 62</a>
    <span style="opacity:.3">|</span>
    <a href="mailto:info@simpaelektrik.com.tr">✉ info@simpaelektrik.com.tr</a>
    <div class="lang">
      <a href="#" class={lang === 'tr' ? 'cur' : ''}>TR</a>
      <a href="#" class={lang === 'en' ? 'cur' : ''}>EN</a>
    </div>
  </div></div>

  <header class="hdr"><div class="hdr-in">
    <a href="/"><img src="/logo.png" alt="Simpa" /></a>
    <nav>
      <a href="/" class="nav-a cur">{lang === 'en' ? 'Products' : 'Ürünlerimiz'}</a>
      <a href="/belgeler" class="nav-a">{lang === 'en' ? 'Catalog' : 'Katalog'}</a>
      <a href="/sertifikalar" class="nav-a">{lang === 'en' ? 'Certificates' : 'Sertifikalar'}</a>
      <a href="/hakkimizda" class="nav-a">{lang === 'en' ? 'About' : 'Hakkımızda'}</a>
      <a href="/iletisim" class="nav-a nav-cta">{lang === 'en' ? 'Contact' : 'İletişim'}</a>
    </nav>
  </div></header>

  <slot />

  <footer class="ftr"><div class="ftr-in">
    <div class="ftr-col"><h4>{lang === 'en' ? 'Products' : 'Ürünler'}</h4><a href="#">Kablo Pabuçları</a><a href="#">Ek Mufları</a><a href="#">Baralar</a></div>
    <div class="ftr-col"><h4>{lang === 'en' ? 'Company' : 'Kurumsal'}</h4><a href="#">Hakkımızda</a><a href="#">Sertifikalar</a></div>
    <div class="ftr-col"><h4>{lang === 'en' ? 'Documents' : 'Belgeler'}</h4><a href="#">Katalog</a><a href="#">Fiyat Listesi</a></div>
  </div><div class="ftr-bot">
    <p>© 2026 Simpa Elektrik Malzemesi San. ve Tic. A.Ş.</p>
    <div class="cert-logos"><span class="cert-badge">ISO</span><span class="cert-badge">CE</span><span class="cert-badge">EAC</span><span class="cert-badge">RoHS</span></div>
  </div></footer>
  </div>
  </div>
</body>
</html>
