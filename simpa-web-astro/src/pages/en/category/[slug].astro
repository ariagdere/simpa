---
// src/pages/en/category/[slug].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import CategoryListing from '../../../components/CategoryListing.astro';
import { getCategoriesWithCounts, getProductsInCategory } from '../../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const { slug } = Astro.params;
const db = env.DB;

const [categories, { category, products }] = await Promise.all([
  getCategoriesWithCounts(db, lang),
  getProductsInCategory(db, slug, lang),
]);

if (!category) {
  return new Response('Category not found', { status: 404 });
}

const categoryName = category.name_en;

// Bu kategorinin TR karşılığı var mı? Yoksa dil switcher'ı "All Products"a düşsün.
const trExists = await db.prepare('SELECT 1 FROM categories WHERE slug = ? AND name_tr IS NOT NULL').bind(slug).first();
const trSwitchOverride = trExists ? `/kategori/${slug}` : '/kategori/';
---
<Layout title={`${categoryName} — Simpa Elektrik`} lang={lang} trSwitchOverride={trSwitchOverride}>
  <CategoryListing categories={categories} activeSlug={slug} title={categoryName} products={products} lang={lang} />
</Layout>
