---
// src/pages/en/index.astro
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getAllCertificates, getHomeStats, getKeyDocuments } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const db = env.DB;

const [certificates, stats, keyDocs] = await Promise.all([getAllCertificates(db), getHomeStats(db), getKeyDocuments(db, null, lang)]);

const varietyRounded = Math.floor(stats.varietyCount / 100) * 100;
---
<Layout title="Simpa Elektrik — Reliable Electrical Connection Solutions" lang={lang}>

<!-- ══════════ DESKTOP ══════════ -->
<div class="desktop-only">
  <div class="hero"><div class="hero-in">
    <div class="hero-l">
      <div class="badge">Since 1977</div>
      <h1>Reliable <em>Electrical Connection</em> Solutions</h1>
      <p>Years of manufacturing experience in compression cable lugs, busbars and connection equipment. ISO 9001, CE and EAC certified products.</p>
      <div class="hero-btns">
        <a href="/en/category/" class="btn-p">Browse Products →</a>
        <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="btn-s"><svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path fill-rule="evenodd" d="M4 4a2 2 0 0 1 2-2h4.586A2 2 0 0 1 12 2.586L15.414 6A2 2 0 0 1 16 7.414V16a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4Zm2 6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H6Zm0 4a1 1 0 1 0 0 2h5a1 1 0 1 0 0-2H6Z" clip-rule="evenodd" /></svg> Download Catalog</a>
      </div>
    </div>
    <div class="hero-r"><img src="https://assets.superpress.com.tr/documents/simpaocak26kattr.png" alt="Simpa Elektrik Catalog" /></div>
  </div></div>

  <div class="stats-bar"><div class="stats-bar-in">
    <div class="stat"><div class="stat-n">45<span>+</span></div><div class="stat-l">Years of experience</div></div>
    <div class="stat"><div class="stat-n">{varietyRounded}<span>+</span></div><div class="stat-l">Product variants</div></div>
    <div class="stat"><div class="stat-n">30<span>+</span></div><div class="stat-l">Countries exported to</div></div>
    <div class="stat"><div class="stat-n">{stats.certCount}<span>+</span></div><div class="stat-l">International certificates</div></div>
  </div></div>

  <div class="sec"><div class="sec-in">
    <div class="hub-grid">
      <a href="/en/category/" class="hub-card">
        <div class="hub-img"><img src="https://assets.superpress.com.tr/urunler.png" alt="Our Products" /></div>
        <div class="hub-body">
          <div class="hub-title">Our Products</div>
          <div class="hub-sub">{stats.catCount} categories, {varietyRounded}+ product variants. The full catalog with technical data.</div>
          <span class="hub-cta">Browse <span class="hub-arr">→</span></span>
        </div>
      </a>
      <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="hub-card accent-blue">
        <div class="hub-img"><img src="https://assets.superpress.com.tr/simpaocak26kare-2.png" alt="Product Catalog" /></div>
        <div class="hub-body">
          <div class="hub-title">Product Catalog</div>
          <div class="hub-sub">View our current product catalog as a PDF and share it with your team.</div>
          <span class="hub-cta">View PDF <span class="hub-arr">→</span></span>
        </div>
      </a>
    </div>
  </div></div>

  <div class="about"><div class="about-in">
    <div>
      <div class="about-lbl">Corporate</div>
      <a href="/en/about" class="about-title title-link">Uninterrupted Production Since 1977</a>
      <div class="about-text">Simpa Elektrik is a well-established Turkish manufacturer founded in 1977. We manufacture electrical connection equipment at our modern facilities.</div>
    </div>
    <div class="tl">
      <div class="tl-item"><div class="tl-dot">77</div><div><div class="tl-year">1977</div><div class="tl-txt">Founded as Simpa Kollektif Şirketi</div></div></div>
      <div class="tl-item"><div class="tl-dot">84</div><div><div class="tl-year">1984</div><div class="tl-txt">Converted into a joint-stock company</div></div></div>
      <div class="tl-item"><div class="tl-dot">CE</div><div><div class="tl-year">2000s</div><div class="tl-txt">CE, EAC and ISO certifications obtained</div></div></div>
      <div class="tl-item"><div class="tl-dot" style="font-size:15px">🌍</div><div><div class="tl-year">Today</div><div class="tl-txt">Exporting to 30+ countries, {varietyRounded}+ product variants</div></div></div>
    </div>
  </div></div>

  {certificates.length > 0 && (
    <div class="certs"><div class="sec-in">
      <div class="sec-hdr">
        <div><a href="/en/certificates" class="sec-title title-link">Certificates &amp; <span>Documents</span></a><div class="sec-sub">All of our products are tested and certified to international standards</div></div>
        <a href="/en/certificates" class="sec-link">All Documents →</a>
      </div>
      <div class="cert-grid">
        {certificates.map((c) => (
          <a href={c.file_url_en || c.file_url_tr} target="_blank" rel="noopener" class="cert-card">
            <div class="cert-card-img">
              {c.image_url ? <img src={c.image_url} alt={c.name} style="max-width:100%;max-height:100%;object-fit:contain" /> : <div class="iso-placeholder"><div class="iso-icon">{c.tag}</div></div>}
            </div>
            <div class="cert-card-info"><div class="cert-card-name">{c.name}</div><div class="cert-card-sub">Certificate / Document</div></div>
          </a>
        ))}
      </div>
    </div></div>
  )}
</div>

<!-- ══════════ MOBILE ══════════ -->
<div class="mobile-only">
  <div class="m-hero">
    <img class="m-hero-img" src="https://assets.superpress.com.tr/documents/simpaocak26kattr.png" alt="Simpa Elektrik Catalog" />
    <div class="m-hero-body">
      <div class="m-badge">Since 1977</div>
      <h1>Reliable <em>Electrical Connection</em> Solutions</h1>
      <p>ISO 9001, CE and EAC certified cable lugs, busbars and connection equipment.</p>
      <div class="m-hero-btns"><a href="/en/category/" class="m-btn-p">Browse Products</a><a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="m-btn-s">Catalog</a></div>
    </div>
  </div>

  <div class="m-stats">
    <div class="m-stat"><div class="m-stat-n">45<span>+</span></div><div class="m-stat-l">Years</div></div>
    <div class="m-stat"><div class="m-stat-n">{varietyRounded}<span>+</span></div><div class="m-stat-l">Products</div></div>
    <div class="m-stat"><div class="m-stat-n">30<span>+</span></div><div class="m-stat-l">Countries</div></div>
    <div class="m-stat"><div class="m-stat-n">{stats.certCount}<span>+</span></div><div class="m-stat-l">Certificates</div></div>
  </div>

  <div class="m-sec">
    <div class="m-hub-grid">
      <a href="/en/category/" class="m-hub-card">
        <div class="m-hub-img"><img src="https://assets.superpress.com.tr/urunler.png" alt="Our Products" /></div>
        <div class="m-hub-body">
          <div class="m-hub-title">Our Products</div>
          <div class="m-hub-sub">{stats.catCount} categories, {varietyRounded}+ product variants</div>
          <span class="m-hub-cta">Browse <span class="m-hub-arr">→</span></span>
        </div>
      </a>
      <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="m-hub-card accent-blue">
        <div class="m-hub-img"><img src="https://assets.superpress.com.tr/simpaocak26kare-2.png" alt="Product Catalog" /></div>
        <div class="m-hub-body">
          <div class="m-hub-title">Product Catalog</div>
          <div class="m-hub-sub">Current catalog, in PDF format</div>
          <span class="m-hub-cta">View PDF <span class="m-hub-arr">→</span></span>
        </div>
      </a>
    </div>
  </div>

  <div class="m-about">
    <div class="m-about-lbl">Corporate</div>
    <h2><a href="/en/about" class="title-link">Since 1977</a></h2>
    <p>Simpa Elektrik is a well-established Turkish manufacturer founded in 1977. All products manufactured at our modern facilities are tested and certified to international standards.</p>
    <div class="tl">
      <div class="tl-item"><div class="tl-dot">77</div><div><div class="tl-year">1977</div><div class="tl-txt">Founded as Simpa Kollektif Şirketi</div></div></div>
      <div class="tl-item"><div class="tl-dot">84</div><div><div class="tl-year">1984</div><div class="tl-txt">Converted into a joint-stock company</div></div></div>
      <div class="tl-item"><div class="tl-dot">CE</div><div><div class="tl-year">2000s</div><div class="tl-txt">CE, EAC and ISO certifications obtained</div></div></div>
      <div class="tl-item"><div class="tl-dot" style="font-size:15px">🌍</div><div><div class="tl-year">Today</div><div class="tl-txt">Exporting to 30+ countries, {varietyRounded}+ product variants</div></div></div>
    </div>
  </div>

  {certificates.length > 0 && (
    <div class="m-certs">
      <a href="/en/certificates" class="m-certs-title title-link">Certificates &amp; Documents</a>
      <div class="m-cert-scroll">
        {certificates.map((c) => (
          <a href={c.file_url_en || c.file_url_tr} target="_blank" rel="noopener" class="m-cert-card">
            <div class="m-cert-card-img">
              {c.image_url ? <img src={c.image_url} alt={c.name} style="max-width:100%;max-height:100%;object-fit:contain" /> : <div class="iso-placeholder"><div class="iso-icon" style="width:40px;height:40px;font-size:9px">{c.tag}</div></div>}
            </div>
            <div class="m-cert-card-info"><b>{c.name}</b><span>Certificate</span></div>
          </a>
        ))}
      </div>
    </div>
  )}
</div>
</Layout>
