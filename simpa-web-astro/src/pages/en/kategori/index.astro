---
// src/pages/en/kategori/index.astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import CategoryListing from '../../../components/CategoryListing.astro';
import { getCategoriesWithCounts, getAllProducts } from '../../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'en';
const db = env.DB;

const [categories, products] = await Promise.all([getCategoriesWithCounts(db, lang), getAllProducts(db, lang)]);
---
<Layout title="Our Products — Simpa Elektrik" lang={lang}>
  <CategoryListing categories={categories} activeSlug={null} title="All Products" products={products} lang={lang} />
</Layout>
