---
// src/pages/index.astro
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import { getAllCertificates, getHomeStats, getKeyDocuments, getActiveHeroSlides } from '../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'tr';
const db = env.DB;

const [certificates, stats, keyDocs, heroSlides] = await Promise.all([
  getAllCertificates(db),
  getHomeStats(db),
  getKeyDocuments(db, null, lang),
  getActiveHeroSlides(db, 'Simpa', lang),
]);

// 1.328 varyant + 12 alet gibi tam sayıyı pazarlama diliyle yuvarlıyoruz (örn. 1340 -> "1.300+")
const varietyRounded = Math.floor(stats.varietyCount / 100) * 100;
---
<Layout title="Simpa Elektrik" lang={lang}>

<HeroSlider slides={heroSlides} />

<!-- ══════════ MASAÜSTÜ ══════════ -->
<div class="desktop-only">
  <div class="stats-bar"><div class="stats-bar-in">
    <div class="stat"><div class="stat-n">45<span>+</span></div><div class="stat-l">Yıl deneyim</div></div>
    <div class="stat"><div class="stat-n">{varietyRounded}<span>+</span></div><div class="stat-l">Ürün çeşidi</div></div>
    <div class="stat"><div class="stat-n">30<span>+</span></div><div class="stat-l">Ülkeye ihracat</div></div>
    <div class="stat"><div class="stat-n">{stats.certCount}<span>+</span></div><div class="stat-l">Uluslararası sertifika</div></div>
  </div></div>

  <div class="sec"><div class="sec-in">
    <div class="hub-grid">
      <a href="/kategori/" class="hub-card">
        <div class="hub-img"><img src="https://assets.superpress.com.tr/urunler.png" alt="Ürünlerimiz" /></div>
        <div class="hub-body">
          <div class="hub-title">Ürünlerimiz</div>
          <div class="hub-sub">{stats.catCount} kategori, {varietyRounded}+ ürün çeşidi. Teknik verilerle birlikte tüm katalog.</div>
          <span class="hub-cta">İncele <span class="hub-arr">→</span></span>
        </div>
      </a>
      <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="hub-card accent-blue">
        <div class="hub-img"><img src="https://assets.superpress.com.tr/simpaocak26kare-2.png" alt="Ürün Kataloğu" /></div>
        <div class="hub-body">
          <div class="hub-title">Ürün Kataloğu</div>
          <div class="hub-sub">Güncel ürün kataloğumuzu PDF olarak görüntüleyin, ekibinizle paylaşın.</div>
          <span class="hub-cta">PDF Görüntüle <span class="hub-arr">→</span></span>
        </div>
      </a>
      {lang === 'tr' && (
        <a href={keyDocs.priceListUrl || '#'} download class="hub-card accent-navy">
          <div class="hub-img"><img src="https://assets.superpress.com.tr/simpafiyatkare.png" alt="Fiyat Listesi" /></div>
          <div class="hub-body">
            <div class="hub-title">Fiyat Listesi</div>
            <div class="hub-sub">Güncel fiyat listesi, Excel formatında hazır.</div>
            <span class="hub-cta">Excel İndir <span class="hub-arr">↓</span></span>
          </div>
        </a>
      )}
    </div>
  </div></div>

  <div class="about"><div class="about-in">
    <div>
      <div class="about-lbl">Kurumsal</div>
      <a href="/hakkimizda" class="about-title title-link">1977'den Bugüne Kesintisiz Üretim</a>
      <div class="about-text">Simpa Elektrik, 1977'de kurulan köklü bir Türk üreticisidir. Modern tesislerimizde elektrik bağlantı malzemeleri üretiyoruz.</div>
    </div>
    <div class="tl">
      <div class="tl-item"><div class="tl-dot">77</div><div><div class="tl-year">1977</div><div class="tl-txt">Simpa Kollektif Şirketi olarak kuruldu</div></div></div>
      <div class="tl-item"><div class="tl-dot">84</div><div><div class="tl-year">1984</div><div class="tl-txt">Anonim şirkete dönüştürüldü</div></div></div>
      <div class="tl-item"><div class="tl-dot">CE</div><div><div class="tl-year">2000s</div><div class="tl-txt">CE, EAC ve ISO sertifikaları alındı</div></div></div>
      <div class="tl-item"><div class="tl-dot" style="font-size:15px">🌍</div><div><div class="tl-year">Bugün</div><div class="tl-txt">30+ ülkeye ihracat, {varietyRounded}+ ürün çeşidi</div></div></div>
    </div>
  </div></div>

  {certificates.length > 0 && (
    <div class="certs"><div class="sec-in">
      <div class="sec-hdr">
        <div><a href="/sertifikalar" class="sec-title title-link">Sertifikalar &amp; <span>Belgeler</span></a><div class="sec-sub">Tüm ürünlerimiz uluslararası standartlara uygun test ve sertifikalandırılmıştır</div></div>
        <a href="/sertifikalar" class="sec-link">Tüm Belgeler →</a>
      </div>
      <div class="cert-grid">
        {certificates.map((c) => (
          <a href={c.file_url_tr || c.file_url_en} target="_blank" rel="noopener" class="cert-card">
            <div class="cert-card-img">
              {c.image_url ? <img src={c.image_url} alt={c.name} style="max-width:100%;max-height:100%;object-fit:contain" /> : <div class="iso-placeholder"><div class="iso-icon">{c.tag}</div></div>}
            </div>
            <div class="cert-card-info"><div class="cert-card-name">{c.name}</div><div class="cert-card-sub">Sertifika / Belge</div></div>
          </a>
        ))}
      </div>
    </div></div>
  )}
</div>

<!-- ══════════ MOBİL ══════════ -->
<div class="mobile-only">
  <div class="m-stats">
    <div class="m-stat"><div class="m-stat-n">45<span>+</span></div><div class="m-stat-l">Yıl</div></div>
    <div class="m-stat"><div class="m-stat-n">{varietyRounded}<span>+</span></div><div class="m-stat-l">Ürün</div></div>
    <div class="m-stat"><div class="m-stat-n">30<span>+</span></div><div class="m-stat-l">Ülke</div></div>
    <div class="m-stat"><div class="m-stat-n">{stats.certCount}<span>+</span></div><div class="m-stat-l">Sertifika</div></div>
  </div>

  <div class="m-sec">
    <div class="m-hub-grid">
      <a href="/kategori/" class="m-hub-card">
        <div class="m-hub-img"><img src="https://assets.superpress.com.tr/urunler.png" alt="Ürünlerimiz" /></div>
        <div class="m-hub-body">
          <div class="m-hub-title">Ürünlerimiz</div>
          <div class="m-hub-sub">{stats.catCount} kategori, {varietyRounded}+ ürün çeşidi</div>
          <span class="m-hub-cta">İncele <span class="m-hub-arr">→</span></span>
        </div>
      </a>
      <a href={keyDocs.catalogUrl || '#'} target="_blank" rel="noopener" class="m-hub-card accent-blue">
        <div class="m-hub-img"><img src="https://assets.superpress.com.tr/simpaocak26kare-2.png" alt="Ürün Kataloğu" /></div>
        <div class="m-hub-body">
          <div class="m-hub-title">Ürün Kataloğu</div>
          <div class="m-hub-sub">Güncel katalog, PDF formatında</div>
          <span class="m-hub-cta">PDF Görüntüle <span class="m-hub-arr">→</span></span>
        </div>
      </a>
      {lang === 'tr' && (
        <a href={keyDocs.priceListUrl || '#'} download class="m-hub-card accent-navy">
          <div class="m-hub-img"><img src="https://assets.superpress.com.tr/simpafiyatkare.png" alt="Fiyat Listesi" /></div>
          <div class="m-hub-body">
            <div class="m-hub-title">Fiyat Listesi</div>
            <div class="m-hub-sub">Excel formatında hazır</div>
            <span class="m-hub-cta">Excel İndir <span class="m-hub-arr">↓</span></span>
          </div>
        </a>
      )}
    </div>
  </div>

  <div class="m-about">
    <div class="m-about-lbl">Kurumsal</div>
    <h2><a href="/hakkimizda" class="title-link">1977'den Bugüne</a></h2>
    <p>Simpa Elektrik, 1977'de kurulan köklü bir Türk üreticisidir. Modern tesislerimizde üretilen tüm ürünler uluslararası standartlara uygun test ve sertifikalandırılmaktadır.</p>
    <div class="tl">
      <div class="tl-item"><div class="tl-dot">77</div><div><div class="tl-year">1977</div><div class="tl-txt">Simpa Kollektif Şirketi olarak kuruldu</div></div></div>
      <div class="tl-item"><div class="tl-dot">84</div><div><div class="tl-year">1984</div><div class="tl-txt">Anonim şirkete dönüştürüldü</div></div></div>
      <div class="tl-item"><div class="tl-dot">CE</div><div><div class="tl-year">2000s</div><div class="tl-txt">CE, EAC ve ISO sertifikaları alındı</div></div></div>
      <div class="tl-item"><div class="tl-dot" style="font-size:15px">🌍</div><div><div class="tl-year">Bugün</div><div class="tl-txt">30+ ülkeye ihracat, {varietyRounded}+ ürün çeşidi</div></div></div>
    </div>
  </div>

  {certificates.length > 0 && (
    <div class="m-certs">
      <a href="/sertifikalar" class="m-certs-title title-link">Sertifikalar &amp; Belgeler</a>
      <div class="m-cert-scroll">
        {certificates.map((c) => (
          <a href={c.file_url_tr || c.file_url_en} target="_blank" rel="noopener" class="m-cert-card">
            <div class="m-cert-card-img">
              {c.image_url ? <img src={c.image_url} alt={c.name} style="max-width:100%;max-height:100%;object-fit:contain" /> : <div class="iso-placeholder"><div class="iso-icon" style="width:40px;height:40px;font-size:9px">{c.tag}</div></div>}
            </div>
            <div class="m-cert-card-info"><b>{c.name}</b><span>Sertifika</span></div>
          </a>
        ))}
      </div>
    </div>
  )}
</div>
</Layout>
