---
// src/pages/kategori/[slug].astro
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import CategoryListing from '../../components/CategoryListing.astro';
import { getCategoriesWithCounts, getProductsInCategory } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'tr';
const { slug } = Astro.params;
const db = env.DB;

const [categories, { category, products }] = await Promise.all([
  getCategoriesWithCounts(db, lang),
  getProductsInCategory(db, slug, lang),
]);

if (!category) {
  return new Response('Kategori bulunamadı', { status: 404 });
}

const categoryName = lang === 'en' ? category.name_en : category.name_tr;

// Bu kategorinin EN karşılığı var mı? Yoksa dil switcher'ı "Tüm Ürünler"e düşsün.
const enExists = await db.prepare('SELECT 1 FROM categories WHERE slug = ? AND name_en IS NOT NULL').bind(slug).first();
const enSwitchOverride = enExists ? `/en/category/${slug}` : '/en/category/';
---
<Layout title={`${categoryName} — Simpa Elektrik`} lang={lang} enSwitchOverride={enSwitchOverride}>
  <CategoryListing categories={categories} activeSlug={slug} title={categoryName} products={products} lang={lang} />
</Layout>
