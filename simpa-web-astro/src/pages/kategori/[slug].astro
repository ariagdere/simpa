---
// src/pages/kategori/[slug].astro
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getCategoriesWithCounts, getProductsInCategory } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const lang = 'tr';
const { slug } = Astro.params;
const db = env.DB;

const [categories, { category, products }] = await Promise.all([
  getCategoriesWithCounts(db, lang),
  getProductsInCategory(db, slug, lang),
]);

if (!category) {
  return new Response('Kategori bulunamadı', { status: 404 });
}

const categoryName = lang === 'en' ? category.name_en : category.name_tr;
const seriesWord = lang === 'en' ? 'series' : 'ürün serisi';
---
<Layout title={`${categoryName} — Simpa Elektrik`} lang={lang}>

<!-- ══════════ MASAÜSTÜ ══════════ -->
<div class="desktop-only">
  <div class="bc"><div class="bc-in">
    <a href="/">Ana Sayfa</a><span>›</span><span class="cur">Ürünlerimiz</span>
  </div></div>

  <div class="cb-header"><div class="cb-header-in">
    <h1>Ürünlerimiz</h1>
    <p>Aşağıdan bir ürün grubu seçin, o gruba ait tüm ürün serilerini hemen altta görüntüleyin.</p>
    <div class="cb-cat-grid">
      {categories.map((c) => (
        <a href={`/kategori/${c.slug}`} class={`cb-cat-card${c.slug === slug ? ' on' : ''}`}>
          <div class="cb-cat-thumb">{c.image_url && <img src={c.image_url} alt={c.name} />}</div>
          <div class="cb-cat-info"><div class="cb-cat-name">{c.name}</div><div class="cb-cat-sub">{c.product_count} {seriesWord}</div></div>
        </a>
      ))}
    </div>
  </div></div>

  <div class="cb-body">
    <div class="cb-grid-hdr">
      <div class="cb-grid-title">{categoryName}</div>
      <div class="cb-grid-count"><strong>{products.length}</strong> {seriesWord}</div>
    </div>
    <div class="cb-grid">
      {products.map((p) => (
        <a href={`/urunler/${p.prod_code}`} class="cb-card">
          <div class="cb-card-img">{p.image && <img src={p.image} alt={p.title} />}</div>
          <div class="cb-card-body">
            <div class="cb-card-code">{p.prod_code}</div>
            <div class="cb-card-name">{p.title}</div>
            {(p.kesitRange || p.civataRange) && (
              <div class="cb-card-specs">
                {p.kesitRange && <div class="cb-card-spec">Kesit: <b>{p.kesitRange} mm²</b></div>}
                {p.civataRange && <div class="cb-card-spec">Civata: <b>{p.civataRange}</b></div>}
              </div>
            )}
            <span class="cb-card-cta">Teknik veriler →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<!-- ══════════ MOBİL ══════════ -->
<div class="mobile-only">
  <div class="m-bc"><a href="/">Ana Sayfa</a><span>›</span><span style="color:var(--g800)">Ürünlerimiz</span></div>

  <div class="m-cb-header">
    <h1>Ürünlerimiz</h1>
    <p>Bir ürün grubu seçin, altında ürün serilerini görün.</p>
    <button class="m-cb-trigger" id="mCbTrigger">
      <div class="m-cb-trigger-text">
        <div class="m-cb-trigger-label">Ürün Grubu</div>
        <div class="m-cb-trigger-val">{categoryName}</div>
      </div>
      <span class="m-cb-trigger-arr">›</span>
    </button>

    <div class="m-drawer-overlay" id="mCbDrawerOverlay">
      <div class="m-drawer-panel">
        <div class="m-drawer-hdr">
          <span>Ürün Grubu Seçin</span>
          <button class="m-drawer-close" id="mCbDrawerClose">✕</button>
        </div>
        <div class="m-drawer-list">
          {categories.map((c) => (
            <a href={`/kategori/${c.slug}`} class={`m-drawer-item${c.slug === slug ? ' on' : ''}`}>
              <div class="m-drawer-info"><div class="m-drawer-name">{c.name}</div><div class="m-drawer-sub">{c.product_count} {seriesWord}</div></div>
              {c.slug === slug && <span class="m-drawer-check">✓</span>}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="m-cb-body">
    <div class="m-cb-grid-hdr">
      <div class="m-cb-grid-title">{categoryName}</div>
      <div class="m-cb-grid-count"><strong>{products.length}</strong> {seriesWord}</div>
    </div>
    <div class="m-cb-list">
      {products.map((p) => (
        <a href={`/urunler/${p.prod_code}`} class="m-cb-card">
          <div class="m-cb-img">{p.image && <img src={p.image} alt={p.title} />}</div>
          <div class="m-cb-body2">
            <div class="m-cb-code">{p.prod_code}</div>
            <div class="m-cb-name">{p.title}</div>
            {(p.kesitRange || p.civataRange) && (
              <div class="m-cb-spec">
                {p.kesitRange && <>Kesit: <b>{p.kesitRange} mm²</b></>}
                {p.kesitRange && p.civataRange && ' · '}
                {p.civataRange && <>Civata: <b>{p.civataRange}</b></>}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</div>
</Layout>

<script>
  const trigger = document.getElementById('mCbTrigger');
  const overlay = document.getElementById('mCbDrawerOverlay');
  const closeBtn = document.getElementById('mCbDrawerClose');
  trigger?.addEventListener('click', () => overlay.classList.add('open'));
  closeBtn?.addEventListener('click', () => overlay.classList.remove('open'));
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
</script>
